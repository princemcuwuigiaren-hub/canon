{
  "name": "Canon — Writing & Story Bible",
  "short_name": "Canon",
  "description": "A writing workspace that treats every novel as a project.",
  "start_url": "canon.html",
  "scope": "./",
  "id": "canon-app",
  "display": "standalone",
  "background_color": "#FFFFFF",
  "theme_color": "#FFFFFF",
  "orientation": "portrait",
  "icons": [
    { "src": "icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" }
  ],
  "share_target": {
    "action": "share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        { "name": "file", "accept": [
          "application/pdf", ".pdf",
          "application/vnd.openxmlformats-officedocument.wordprocessingml.document", ".docx",
          "text/markdown", ".md", ".markdown",
          "text/plain", ".txt"
        ] }
      ]
    }
  }
}
